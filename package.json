{
  "name": "power-slides",
  "version": "3.0.0",
  "description": "ESM-first reusable talk kit and tiny slideshow runtime for content-only browser talks.",
  "main": "index.js",
  "scripts": {
    "example": "node bin/power-slides.js dev examples/starter",
    "build": "node bin/power-slides.js build examples/starter",
    "test": "standard && node --test && node test/cli-smoke.js"
  },
  "keywords": [
    "slides",
    "slideshow",
    "talks",
    "presentations",
    "esm"
  ],
  "author": "David Guttman <david@guttman.io> (http://davidguttman.com/)",
  "license": "MIT",
  "dependencies": {
    "browserify": "^17.0.1",
    "budo": "^11.8.4",
    "esmify": "^2.1.1",
    "hyperscript": "^1.4.7",
    "js-yaml": "^4.1.1",
    "peerjs": "^1.5.5",
    "qrcode-generator": "^1.4.4",
    "terser": "^5.48.0",
    "wildemitter": "^1.2.0",
    "xtend": "^4.0.2"
  },
  "devDependencies": {
    "standard": "^17.1.2"
  },
  "directories": {
    "example": "examples/starter"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidguttman/power-slides.git"
  },
  "bugs": {
    "url": "https://github.com/davidguttman/power-slides/issues"
  },
  "homepage": "https://github.com/davidguttman/power-slides#readme",
  "standard": {
    "env": [
      "browser",
      "node",
      "es2021"
    ],
    "ignore": [
      "examples/**/public/power-slides.*.js"
    ]
  },
  "module": "index.mjs",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./cli": "./bin/power-slides.js"
  },
  "bin": {
    "power-slides": "bin/power-slides.js",
    "powerslides": "bin/power-slides.js"
  },
  "files": [
    "index.js",
    "index.mjs",
    "remote.js",
    "bin",
    "examples/starter/slides.yaml",
    "examples/starter/talk.js",
    "examples/starter/assets",
    "examples/starter/public/sample.svg",
    "examples/starter/public/title.png",
    "examples/starter/public/deploy.png",
    "examples/starter/public/github-render.png",
    "examples/starter/public/build-it.png",
    "examples/starter/public/workflow.png",
    "examples/starter/public/fractal-loop.mp4",
    "README.md"
  ]
}
