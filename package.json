{
  "name": "power-slides",
  "version": "1.6.0",
  "description": "Create powerful slideshows for talks and presentations. Each \"slide\" is a JS function that can do *anything*.",
  "main": "index.js",
  "scripts": {
    "example": "budo example/index.js --port ${PORT:-9966} --open",
    "test": "standard"
  },
  "keywords": [
    "slides",
    "slideshow"
  ],
  "author": "David Guttman <david@guttman.io> (http://davidguttman.com/)",
  "license": "MIT",
  "dependencies": {
    "hyperscript": "^1.4.7",
    "wildemitter": "^1.2.0",
    "xtend": "^4.0.2"
  },
  "devDependencies": {
    "browserify": "^17.0.1",
    "budo": "^11.8.4",
    "standard": "^17.1.2"
  },
  "directories": {
    "example": "example"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidguttman/power-slides.git"
  },
  "bugs": {
    "url": "https://github.com/davidguttman/power-slides/issues"
  },
  "homepage": "https://github.com/davidguttman/power-slides#readme",
  "standard": {
    "env": [
      "browser"
    ]
  }
}
